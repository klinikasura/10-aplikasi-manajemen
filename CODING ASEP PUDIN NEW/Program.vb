Module Module1
    Sub Main()
        Dim a As Integer
        Dim b As Integer
        Dim hasil As Integer

        Console.Write("Masukkan angka pertama: ")
        a = Console.ReadLine()

        Console.Write("Masukkan angka kedua: ")
        b = Console.ReadLine()

        hasil = a + b

        Console.WriteLine("Hasil: " & hasil)
        Console.ReadLine()
    End Sub
End Module
